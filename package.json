{
  "name": "ldev-auction",
  "private": true,
  "type": "module",
  "scripts": {
    "setup:env": "bun scripts/generate-env.ts",
    "collector:release": "bun scripts/publish-collector-release.ts",
    "dev": "vp dev --port 3005",
    "build": "vp build",
    "lint": "bunx wrangler types && bun run format",
    "format": "vp check --fix && vp lint --type-aware --fix",
    "deploy": "bun run build && wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler --config ./wrangler.jsonc d1 migrations apply auction --local",
    "db:apply-prod": "wrangler --config ./wrangler.jsonc d1 migrations apply auction --remote",
    "legacy:styles:build": "bunx @tailwindcss/cli -i ./src/styles/app.css -o ./public/app.css --minify",
    "legacy:client:build": "bun build src/ui/client.tsx --outfile public/app.js --target browser --minify",
    "legacy:assets:build": "bun run legacy:styles:build && bun run legacy:client:build",
    "legacy:build:server:bin": "bun run legacy:assets:build && bun scripts/build-server-executable.ts",
    "legacy:dev": "bun run legacy:styles:build && bun --watch src/server.tsx",
    "legacy:start": "bun src/server.tsx",
    "collector:headed": "bash ./scripts/run-headed-collector.sh",
    "sold-prices:headed": "bash ./scripts/run-sold-price-runner.sh",
    "collector:bootstrap": "bun collector/bootstrap.ts --public-key-file ./runner-keys/collector-signing-key.pub.pem",
    "collector:local": "bun collector/auction-runner.ts",
    "check:server": "bun src/server.tsx"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "1.33.1",
    "@radix-ui/react-hover-card": "1.1.15",
    "@radix-ui/react-slot": "1.2.4",
    "@tailwindcss/vite": "4.2.4",
    "@tanstack/react-router": "1.168.23",
    "@tanstack/react-start": "1.167.42",
    "@tanstack/router-plugin": "1.167.22",
    "better-auth": "1.5.6",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "lucide-react": "1.7.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "3.5.0",
    "web-push": "3.6.7"
  },
  "devDependencies": {
    "@tailwindcss/cli": "4.2.2",
    "@types/bun": "1.3.11",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/web-push": "3.6.4",
    "@vitejs/plugin-react": "6.0.1",
    "drizzle-kit": "0.31.10",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "wrangler": "4.84.1"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  }
}
