{
  "name": "ldev-auction",
  "private": true,
  "type": "module",
  "scripts": {
    "setup:env": "bun scripts/generate-env.ts",
    "collector:release": "bun scripts/publish-collector-release.ts",
    "dev": "vp dev",
    "build": "vp build",
    "lint": "bunx wrangler types && bun run format",
    "format": "vp check --fix && vp lint --type-aware --fix",
    "deploy": "bun run build && wrangler deploy",
    "dep:update": "npx -y npm-check-updates -u",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler --config ./wrangler.jsonc d1 migrations apply auction --local",
    "db:apply-prod": "wrangler --config ./wrangler.jsonc d1 migrations apply auction --remote",
    "collector:headed": "bash ./scripts/run-headed-collector.sh",
    "sold-prices:headed": "bash ./scripts/run-sold-price-runner.sh",
    "collector:bootstrap": "bun collector/bootstrap.ts --public-key-file ./runner-keys/collector-signing-key.pub.pem",
    "collector:local": "bun collector/auction-runner.ts"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "1.35.0",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-hover-card": "1.1.15",
    "@radix-ui/react-slot": "1.2.4",
    "@tailwindcss/vite": "4.2.4",
    "@tanstack/react-router": "1.169.1",
    "@tanstack/react-start": "1.167.57",
    "@tanstack/router-plugin": "1.167.31",
    "better-auth": "1.6.9",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "1.0.0-rc.1",
    "lucide-react": "1.14.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tailwind-merge": "3.5.0",
    "web-push": "3.6.7"
  },
  "devDependencies": {
    "@types/bun": "1.3.13",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/web-push": "3.6.4",
    "@vitejs/plugin-react": "6.0.1",
    "drizzle-kit": "1.0.0-rc.1",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "wrangler": "4.87.0"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  }
}
