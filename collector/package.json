{
  "name": "lnh-auction-collector",
  "private": true,
  "type": "module",
  "version": "2026.04.06.2",
  "scripts": {
    "build": "bun run build.ts",
    "bootstrap": "bun run build && bun ./dist/bootstrap.js",
    "bootstrap:src": "bun run bootstrap.ts",
    "collect": "bun run build && bun ./dist/auction-runner.js",
    "collect:src": "bun run auction-runner.ts",
    "typecheck": "bunx tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "luxon": "3.7.2",
    "playwright": "1.58.2"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "@types/luxon": "3.7.1",
    "@types/node": "25.5.0"
  }
}
